  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "tsc": "tsc --skipLibCheck --noEmit",
    "lint": "eslint . --fix",
    "clean": "rm -rf node_modules",
